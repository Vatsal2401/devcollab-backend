# Application
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=8h

# Database
DATABASE_PATH=/opt/devcollab/devcollab.db

# Git
WORKSPACES_PATH=/workspaces/active
PLANS_PATH=/plans
ENVS_PATH=/opt/devcollab/envs
PREVIEW_BRANCH=preview
MAIN_BRANCH=main

# GitHub
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_OWNER=your-org-or-username
GITHUB_REPO=your-repo-name
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL_PLANS=#plans
SLACK_CHANNEL_DEV=#dev
SLACK_CHANNEL_REVIEW=#review
SLACK_CHANNEL_QA=#qa
SLACK_CHANNEL_BUGS=#bugs
SLACK_CHANNEL_RELEASES=#releases
SLACK_CHANNEL_INCIDENTS=#incidents

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=devcollab@yourcompany.com

# PM2 (for preview server restarts)
PM2_PREVIEW_APP_NAME=preview-server
